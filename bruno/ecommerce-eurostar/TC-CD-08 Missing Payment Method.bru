meta {
  name: TC-CD-08 Missing Payment Method
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/checkout
  body: json
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "productIds": [1]
  }
}

tests {
  test("status is 400", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("error message is returned", function() {
    expect(res.getBody().error).to.equal("paymentMethod is required");
  });
}
