    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@usebruno/cli": "^3.4.2",
    "chai": "^4.5.0",
    "mocha": "^11.1.0",
    "mochawesome": "^7.1.3",
    "supertest": "^7.1.0"
  }
