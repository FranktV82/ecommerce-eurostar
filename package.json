{
  "name": "ecommerce-eurostar",
  "version": "1.0.0",
  "description": "E-commerce REST API with JWT authentication and checkout",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test:bruno": "cd bruno/ecommerce-eurostar && bru run --env local",
